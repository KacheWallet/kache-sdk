{
  "name": "@kache/sdk",
  "version": "1.0.0",
  "description": "dApp connector for the Kache Kaspa wallet — connect, read account/balance, sign messages, and request KAS transfers via window.kache.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "kaspa",
    "kache",
    "wallet",
    "dapp",
    "sdk",
    "provider"
  ],
  "author": "Kache",
  "homepage": "https://github.com/KacheWallet/kache-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KacheWallet/kache-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/KacheWallet/kache-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}
